# research-to-site .env.example
# Copy this file to ~/.deep-research-agent/.env and fill in all values.
# That path is the global config anchor — every subagent sources it from there.
#
# Install:
#   mkdir -p ~/.deep-research-agent
#   cp .env.example ~/.deep-research-agent/.env
#   nano ~/.deep-research-agent/.env

# ── Deep Research Agent ──────────────────────────────────────────────────────
# Git source — OKF flat output merged to main (PR #2)
DEEP_RESEARCH_AGENT_REPO=https://github.com/mister2d/deep-research-agent.git
DEEP_RESEARCH_AGENT_BRANCH=main
# Where the agent will be cloned (auto-cloned on first run if missing)
DEEP_RESEARCH_AGENT_DIR=/opt/agents/deep-research-agent

# Output workspace (default matches deep-research-agent's own default).
# NOTE: this workspace is a git repo managed by `factory init` — worker worktrees are
# worktrees of it, and completed runs are rolled up onto its `main` branch.
DEEP_RESEARCH_WORKSPACE=~/.deep-research-agent/workspace

# ── Self-Hosted Infrastructure ───────────────────────────────────────────────
# SearXNG for web search
SEARXNG_URL=

# Crawl4AI for content extraction (HTML)
CRAWL4AI_URL=
CRAWL4AI_TOKEN=

# Apache Tika for document intelligence (Office, PDF, EPUB, images)
TIKA_URL=

# LLM endpoint
LLM_BASE_URL=
LLM_MODEL=qwen3.6-35b-a3b

# Hybrid web search skill directory
HYBRID_SEARCH_SKILL_DIR=

# ── Optional ─────────────────────────────────────────────────────────────────
# Default artifact delivery dir for built sites. If set, every built site is copied
# to $FACTORY_DELIVER_DIR/<run_id>/ (a `| deliver to: <dir>` suffix overrides it per-run).
FACTORY_DELIVER_DIR=

# ngrok auth token — only needed for `factory-share` to expose a built site publicly.
NGROK_AUTHTOKEN=
